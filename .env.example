# === ScamSence MVP — Environment Variables ===
# Скопируй этот файл как .env и заполни свои ключи
# cp .env.example .env

# Claude API (опционально — для сложных запросов)
ANTHROPIC_API_KEY=your_key_here

# Ollama (локальная модель)
OLLAMA_BASE_URL=http://localhost:11434

# Rate limiting
FREE_CHECKS_PER_DAY=5

# App settings
APP_ENV=development
APP_PORT=8000
STREAMLIT_PORT=8501
